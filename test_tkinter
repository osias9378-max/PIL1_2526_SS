import json


with open("agenda.json" ,"r") as calendar:
      agenda=json.load(calendar)
def tache (date):
        tache_affiche=""
        if date in agenda :
                for i,j in enumerate(agenda[date]) :
                         tache_affiche+=f"{i+1}-{j}\n"
                sms.config(text=tache_affiche)
